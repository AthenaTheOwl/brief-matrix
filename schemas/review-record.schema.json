{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brief-matrix.local/schemas/review-record.schema.json",
  "title": "BriefMatrix Review Record",
  "description": "One row per status transition on a brief.",
  "type": "object",
  "required": [
    "tenant_id",
    "iso_week",
    "from_status",
    "to_status",
    "reviewer",
    "decided_at"
  ],
  "additionalProperties": false,
  "properties": {
    "tenant_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$"
    },
    "iso_week": {
      "type": "string",
      "pattern": "^\\d{4}-W\\d{2}$"
    },
    "from_status": {
      "type": "string",
      "enum": ["pending-review", "approved", "rejected"]
    },
    "to_status": {
      "type": "string",
      "enum": ["pending-review", "approved", "rejected"]
    },
    "reviewer": { "type": "string", "minLength": 1 },
    "decided_at": { "type": "string", "format": "date-time" },
    "notes": { "type": "string" }
  }
}
