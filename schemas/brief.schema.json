{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brief-matrix.local/schemas/brief.schema.json",
  "title": "BriefMatrix Brief Artifact",
  "description": "Structured representation of a per-tenant weekly brief.",
  "type": "object",
  "required": [
    "tenant_id",
    "iso_week",
    "sections",
    "citations",
    "voice_lint_pass",
    "review_status"
  ],
  "additionalProperties": false,
  "properties": {
    "tenant_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$"
    },
    "iso_week": {
      "type": "string",
      "pattern": "^\\d{4}-W\\d{2}$"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "body"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "body": { "type": "string" }
        }
      }
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_url", "inline_claim"],
        "additionalProperties": false,
        "properties": {
          "source_url": { "type": "string", "format": "uri" },
          "inline_claim": { "type": "string", "minLength": 1 }
        }
      }
    },
    "voice_lint_pass": { "type": "boolean" },
    "review_status": {
      "type": "string",
      "enum": ["pending-review", "approved", "rejected"]
    }
  }
}
